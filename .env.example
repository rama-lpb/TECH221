# Configuration de l'environnement - Exemple pour le déploiement
# IMPORTANT: Copier ce fichier en .env et remplir les valeurs

# ===========================================
# CONFIGURATION SERVEUR
# ===========================================

# Port du serveur (sur Render, utiliser 10000)
PORT=10000

# Environnement (production sur Render)
NODE_ENV=production

# ===========================================
# CONFIGURATION BASE DE DONNÉES
# ===========================================

# URL de connexion PostgreSQL
# En local: utilise l'EXTERNAL Database URL (Render) et ajoute souvent `?sslmode=require`
# (l'Internal Database URL Render, hostname du type `dpg-xxxx-a` sans domaine, n'est pas accessible depuis ta machine)
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://username:password@host:5432/database_name?sslmode=require

# ===========================================
# CONFIGURATION CLOUDINARY (Upload d'images)
# ===========================================

# Nom du cloud Cloudinary (trouvé dans le dashboard Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Clé API Cloudinary
CLOUDINARY_API_KEY=your_api_key

# Secret API Cloudinary
CLOUDINARY_API_SECRET=your_api_secret
