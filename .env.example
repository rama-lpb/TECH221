# Configuration de l'environnement - Exemple pour le déploiement
# IMPORTANT: Copier ce fichier en .env et remplir les valeurs

# ===========================================
# CONFIGURATION SERVEUR
# ===========================================

# Port du serveur (sur Render, utiliser 10000)
PORT=10000

# Environnement (production sur Render)
NODE_ENV=production

# ===========================================
# CONFIGURATION BASE DE DONNÉES
# ===========================================

# URL de connexion PostgreSQL (fournie par Render après création de la base)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://username:password@host:port/database_name

# ===========================================
# CONFIGURATION CLOUDINARY (Upload d'images)
# ===========================================

# Nom du cloud Cloudinary (trouvé dans le dashboard Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Clé API Cloudinary
CLOUDINARY_API_KEY=your_api_key

# Secret API Cloudinary
CLOUDINARY_API_SECRET=your_api_secret